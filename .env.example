# Backend URL. Set to your deployed backend (Railway/Fly/VPS) for production.
# Example (Railway): VITE_BACKEND_URL=https://caddy-control-api.up.railway.app
VITE_BACKEND_URL=http://localhost:3001

# Mapbox access token. Create one at https://account.mapbox.com/access-tokens/
# This is exposed to the browser, so use a public `pk.*` token with URL restrictions.
VITE_MAPBOX_TOKEN=pk.put_your_public_token_here
