{
  "name": "caddy-control-server",
  "version": "1.0.0",
  "description": "Caddy Control backend: iStartek VT-100 TCP server, fence/bypass engine, REST+WS API, SQLite persistence",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "simulate": "tsx test/simulator.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:seed": "tsx src/persistence/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^11.3.0",
    "fastify": "^4.28.1",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "socket.io": "^4.8.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.5.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
